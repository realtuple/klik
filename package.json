{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/css": "^0.14.1",
        "@eslint/js": "^10.0.1",
        "@eslint/markdown": "^7.5.1",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^16.3.1",
        "prettier": "3.8.1",
        "tailwindcss": "^4.0.0",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.0.7",
        "vite-svg-loader": "^5.1.0"
    },
    "dependencies": {
        "@erag/lang-sync-inertia": "^1.4.12",
        "@inertiajs/vue3": "^2.3.15",
        "@vitejs/plugin-vue": "^6.0.4",
        "reka-ui": "^2.8.2",
        "tw-animate-css": "^1.4.0",
        "vue": "^3.5.28",
        "ziggy-js": "^2.6.1"
    },
    "lint-staged": {
        "*.{js,ts,vue,md}": [
            "npx eslint --fix",
            "npx prettier --write"
        ],
        "*.php": [
            "./vendor/bin/pint",
            "./vendor/bin/phpstan analyse"
        ]
    }
}
